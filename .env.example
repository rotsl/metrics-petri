# Copy this file to `.env` for local development.

# Hosted Gemini / Gemma API settings
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"
GEMINI_MODEL="gemma-3-27b-it"

# Local Gemma MLX prior
# Download with: make download-gemma-model
LOCAL_MODEL_DIR="models/gemma-4-e2b-it-MLX-4bit"
LOCAL_MODEL_ID="models/gemma-4-e2b-it-MLX-4bit"
LOCAL_ENABLE_MLX="1"

# Local segmentation checkpoints
# U-Net checkpoint must be placed manually at LOCAL_UNET_PATH
# SAM checkpoint can be downloaded with: make download-sam-model
LOCAL_UNET_PATH="models/best_unet.pt"
LOCAL_SAM_CHECKPOINT="models/sam_vit_b_01ec64.pth"
LOCAL_SAM_MODEL_TYPE="vit_b"

# Local API server
API_PORT="8000"
